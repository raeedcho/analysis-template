[build-system]
requires = [
    "setuptools>=61.0.0",
    "wheel"
]
build-backend = "setuptools.build_meta"

[project]
name = "{{ package_name }}"
version = "0.1.0"
description = "{{ description }}"
authors = [
    { name = "{{ author_name }}" }
]
readme = "README.md"
requires-python = "{{ python_version }}"
dependencies = [
    "numpy",
    "pandas",
    "pyarrow",
    "scipy",
    "matplotlib",
    "seaborn",
    "scikit-learn",
]

[project.optional-dependencies]
dev = [
    "pytest",
    "pytest-cov",
    "ruff",
]

[tool.setuptools.packages.find]
where = ["."]

# ── Tool configuration ─────────────────────────────────────────────────────

[tool.pytest.ini_options]
testpaths = ["tests"]

[tool.ruff]
line-length = 88
{% raw %}src = ["{{ package_name }}", "scripts"]{% endraw %}

[tool.ruff.lint]
select = ["E", "F", "W", "I", "UP"]
